    "Sleeptab reads sleep from Apple Health.\nWear your watch tonight, or check\nHealth → Sharing → Apps → Sleeptab.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Sleeptab 通过“健康”读取睡眠数据。\n今晚戴上手表，或在\n“健康” → 共享 → App → Sleeptab 中查看。"
          }
        }
      }
    },
